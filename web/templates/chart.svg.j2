<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="0 0 1200 1400" width="1200" height="1400">
  <defs>
    <style type="text/css"><![CDATA[
      .bg          { fill: #faf6ec; }
      .card        { fill: #ffffff; stroke: #d4cdb6; stroke-width: 1.5; }
      .card-empty  { fill: #f5f1e3; stroke: #d4cdb6; stroke-width: 1.5; stroke-dasharray: 4 4; }
      .card-head   { fill: #6e5832; }
      .card-head-empty { fill: #c5beaa; }
      .border      { stroke: #cbc0a3; stroke-width: 1; fill: none; }
      .ru-text     { font-family: "Inter", "Helvetica Neue", "Helvetica", Arial, "PingFang SC", "Noto Sans CJK SC", sans-serif; fill: #3d2f18; }
      .label-sm    { font-size: 16px; fill: #ffffff; font-weight: 600; letter-spacing: 1px; }
      .ru-meta     { font-size: 16px; fill: #6e5832; }
      .ru-sub      { font-size: 14px; fill: #8a7250; }
      .ru-mute     { font-size: 16px; fill: #a99c81; }
      .title       { font-family: "Inter", "Helvetica Neue", sans-serif; font-size: 32px; font-weight: 700; fill: #2d1f10; }
      .subtitle    { font-size: 18px; fill: #6e5832; }
      /* macOS family names lead the list because Cairo on macOS resolves
         them through CoreText. On Linux containers fontconfig has no
         knowledge that "PingFang SC" is a CJK family, so we install an
         alias rule (see Dockerfile) that redirects unknown CJK family
         names to Noto Sans CJK SC. Without that alias, fc-match falls
         through to DejaVu Sans → tofu boxes. */
      .glyph       { font-family: "PingFang SC", "Hiragino Sans GB", "Noto Sans CJK SC", "Noto Serif CJK SC", "Songti SC", serif; font-weight: 700; text-anchor: middle; }
      .stem-char   { font-size: 110px; }
      .branch-char { font-size: 100px; }
      /* Shadow copy of every large CJK glyph — drawn first, with an
         offset and a dark fill, so the coloured glyph above it reads as
         slightly raised off the card. Defined late so its `fill` wins
         over the .el-* class on the same <text>. */
      .glyph-shadow { fill: #1a1208 !important; opacity: 0.45; }
      .hidden-char { font-size: 30px; fill: #8a7250; }
      .hidden-stem { font-weight: 700; }
      .hidden-yy   { font-size: 13px; fill: #8a7250; }
      .ten-god     { font-size: 26px; fill: #4a3a20; }
      .placeholder { font-size: 90px; fill: #c5beb0; text-anchor: middle; }
      .footer      { font-size: 14px; fill: #8a7250; text-anchor: middle; letter-spacing: 1.5px; }
      .balance-label  { font-family: "Inter", sans-serif; font-size: 19px; fill: #3d2f18; }
      .balance-glyph  { font-family: "PingFang SC", "Noto Sans CJK SC", serif; font-size: 26px; font-weight: 700; }
      .balance-pct    { font-family: "Inter", sans-serif; font-size: 17px; fill: #6e5832; }
      .role-label  { font-family: "Inter", sans-serif; font-size: 18px; font-weight: 600; fill: #3d2f18; }
      .role-label-dm { fill: #6e5832; font-size: 20px; font-weight: 700; }
      /* Emoji preference: macOS native first ("Apple Color Emoji"), then
         Twemoji on Linux (Twitter's open-source set, the closest visual
         match to Apple — round colour glyphs), then Noto Color Emoji as
         broad fallback. Apple's font isn't licensed for Linux, so we
         pick the next-most-Apple-looking family our containers can ship
         legally. Pango/Cairo will actually use whichever the system
         resolves first via fontconfig. */
      .wuxing-emoji { font-family: "Apple Color Emoji", "Twemoji Mozilla", "Twemoji", "Noto Color Emoji", "Segoe UI Emoji", sans-serif; font-size: 60px; text-anchor: middle; }
      .wuxing-emoji-dm { font-size: 78px; }
      .dm-stem-big { font-family: "PingFang SC", "Hiragino Sans GB", "Noto Sans CJK SC", "Songti SC", serif; font-weight: 900; font-size: 56px; }
      .dm-name-big { font-family: "Inter", "Helvetica Neue", sans-serif; font-size: 32px; font-weight: 600; fill: #2d1f10; }
      .arrow-line  { stroke-width: 3; fill: none; stroke-linecap: round; opacity: 0.92; }
      .arrow-ctrl  { stroke-width: 1.8; fill: none; stroke-linecap: round; stroke-dasharray: 5 5; opacity: 0.78; }
      .arrow-tip-gen  { fill: #a89066; stroke: #a89066; stroke-width: 1; stroke-linejoin: round; }
      .arrow-tip-ctrl { fill: #c46c4a; stroke: #c46c4a; stroke-width: 0.8; stroke-linejoin: round; opacity: 0.92; }
      .legend-line { stroke: #a89066; stroke-width: 2.5; fill: none; stroke-linecap: round; }
      .legend-ctrl { stroke: #c46c4a; stroke-width: 1.6; fill: none; stroke-dasharray: 5 4; opacity: 0.85; }
      .el-wood    { fill: #5fa86a; }
      .el-fire    { fill: #d04a3a; }
      .el-earth   { fill: #a06030; }
      .el-metal   { fill: #7a8190; }
      .el-water   { fill: #3a78c4; }
      .el-bg-wood   { fill: #5fa86a; }
      .el-bg-fire   { fill: #d04a3a; }
      .el-bg-earth  { fill: #a06030; }
      .el-bg-metal  { fill: #7a8190; }
      .el-bg-water  { fill: #3a78c4; }
    ]]></style>

    <!-- Arrowheads are drawn as plain <path> shapes in the body of the
         document with vertex coordinates computed in Python (no SVG
         transforms). CairoSVG silently drops orient="auto" on <marker>
         and inconsistently applies transform="rotate(...)" on <polygon>,
         so we hand it absolute geometry. -->

    <!-- Tighter shadow for the wuxing arrowheads — adds volume so the
         calligraphic tip lifts off the canvas. CairoSVG has good support
         for feDropShadow at small stdDeviation; on large glyphs we use a
         duplicate-text technique instead because blur quality degrades. -->
    <filter id="tip-shadow" x="-50%" y="-50%" width="200%" height="200%">
      <feDropShadow dx="0.5" dy="1" stdDeviation="0.6" flood-color="#3a2810" flood-opacity="0.55"/>
    </filter>

    <!-- Element icons as reusable symbols (no Chinese glyphs) -->
    <symbol id="ic-wood" viewBox="-30 -30 60 60">
      <rect x="-4" y="-2" width="8" height="22" fill="#3a5b1f"/>
      <circle cx="0" cy="-8" r="20" fill="#ffffff" opacity="0.92"/>
      <circle cx="-7" cy="-12" r="9" fill="#ffffff" opacity="0.92"/>
      <circle cx="9" cy="-10" r="8" fill="#ffffff" opacity="0.92"/>
      <circle cx="0" cy="-3" r="9" fill="#ffffff" opacity="0.92"/>
    </symbol>
    <symbol id="ic-fire" viewBox="-30 -30 60 60">
      <path d="M 0,-22 C -10,-10 -16,0 -14,8 C -12,18 -4,22 0,22 C 6,22 14,18 14,6 C 14,-2 8,-12 0,-22 Z M -3,4 C -2,-2 1,-6 4,-10 C 6,-2 8,4 6,10 C 4,16 -2,17 -4,12 C -6,8 -5,6 -3,4 Z" fill="#ffffff" opacity="0.95"/>
    </symbol>
    <symbol id="ic-earth" viewBox="-30 -30 60 60">
      <path d="M -22,16 L -8,-4 L -2,8 L 6,-12 L 22,16 Z" fill="#ffffff" opacity="0.95"/>
      <circle cx="-12" cy="-12" r="3" fill="#ffffff"/>
    </symbol>
    <symbol id="ic-metal" viewBox="-30 -30 60 60">
      <circle cx="0" cy="0" r="20" fill="none" stroke="#ffffff" stroke-width="3.5"/>
      <circle cx="0" cy="0" r="6" fill="#ffffff"/>
      <line x1="-26" y1="0" x2="-22" y2="0" stroke="#ffffff" stroke-width="3.5"/>
      <line x1="22" y1="0" x2="26" y2="0" stroke="#ffffff" stroke-width="3.5"/>
      <line x1="0" y1="-26" x2="0" y2="-22" stroke="#ffffff" stroke-width="3.5"/>
      <line x1="0" y1="22" x2="0" y2="26" stroke="#ffffff" stroke-width="3.5"/>
    </symbol>
    <symbol id="ic-water" viewBox="-30 -30 60 60">
      <path d="M 0,-22 C -12,-6 -16,4 -16,10 C -16,18 -8,24 0,24 C 8,24 16,18 16,10 C 16,4 12,-6 0,-22 Z" fill="#ffffff" opacity="0.95"/>
      <ellipse cx="-5" cy="6" rx="3" ry="6" fill="#ffffff" opacity="0.5"/>
    </symbol>
  </defs>

  <!-- Background -->
  <rect class="bg" width="1200" height="1380"/>

  <!-- Header -->
  <text x="40" y="55" class="ru-text title">{{ title }}</text>
  <text x="1160" y="55" class="ru-text subtitle" text-anchor="end">{{ subtitle }}</text>
  <line x1="40" y1="75" x2="1160" y2="75" class="border"/>

  <!-- Pillars row (always 4 columns, hour can be empty placeholder) -->
  {% for p in pillars %}
  {% set x0 = 40 + loop.index0 * 282 %}
  <g transform="translate({{ x0 }}, 100)">
    {% if p.empty %}
    <rect class="card-empty" x="0" y="0" width="270" height="580" rx="6"/>
    <rect class="card-head-empty" x="0" y="0" width="270" height="36" rx="6"/>
    <rect class="card-head-empty" x="0" y="20" width="270" height="16"/>
    <text x="135" y="24" class="label-sm" text-anchor="middle">{{ p.label }}</text>
    <text x="135" y="220" class="placeholder">—</text>
    <text x="135" y="400" class="placeholder">—</text>
    <text x="135" y="480" class="ru-text ru-mute" text-anchor="middle">время не указано</text>
    <text x="135" y="510" class="ru-text ru-sub" text-anchor="middle">столп часа не построен</text>
    {% else %}
    <rect class="card" x="0" y="0" width="270" height="580" rx="6"/>
    <rect class="card-head" x="0" y="0" width="270" height="36" rx="6"/>
    <rect class="card-head" x="0" y="20" width="270" height="16"/>
    <text x="135" y="24" class="label-sm" text-anchor="middle">{{ p.label }}</text>
    <text x="135" y="62" class="ru-text ru-meta" text-anchor="middle">{{ p.stem_yin_yang }}</text>
    <text x="138" y="205" class="glyph stem-char glyph-shadow">{{ p.stem }}</text>
    <text x="135" y="200" class="glyph stem-char el-{{ p.stem_el }}">{{ p.stem }}</text>
    <text x="135" y="248" class="ru-text ru-meta" text-anchor="middle">{{ p.branch_yin_yang }}</text>
    <text x="138" y="385" class="glyph branch-char glyph-shadow">{{ p.branch }}</text>
    <text x="135" y="380" class="glyph branch-char el-{{ p.branch_el }}">{{ p.branch }}</text>
    <text x="135" y="420" class="ru-text ru-meta" text-anchor="middle">{{ p.branch_animal }}</text>
    <line x1="20" y1="445" x2="250" y2="445" class="border"/>
    <text x="135" y="465" class="ru-text ru-sub" text-anchor="middle">скрытые</text>
    {% if p.hidden_list %}
      {% for hs in p.hidden_list %}
      <text x="{{ hs.x }}" y="500" class="glyph hidden-stem el-{{ hs.el }}" style="font-size: 32px;">{{ hs.char }}</text>
      <text x="{{ hs.x }}" y="520" class="ru-text hidden-yy" text-anchor="middle">{{ hs.yin_yang }}</text>
      {% endfor %}
    {% else %}
      <text x="135" y="500" class="glyph hidden-char">—</text>
    {% endif %}
    <line x1="20" y1="535" x2="250" y2="535" class="border"/>
    <text x="135" y="563" class="glyph ten-god">{{ p.ten_god_stem }}</text>
    {% endif %}
  </g>
  {% endfor %}

  <!-- Господин дня (narrow card, left) ─ Wuxing (wide card, right) ───────── -->

  <!-- Господин дня: narrow column on the left -->
  <g transform="translate(40, 700)">
    <rect class="card" x="0" y="0" width="300" height="440" rx="6"/>
    <text x="24" y="32" class="ru-text ru-sub" style="letter-spacing: 1.2px;">ГОСПОДИН ДНЯ</text>
    <line x1="20" y1="48" x2="280" y2="48" class="border"/>
    <text x="155" y="248" class="glyph stem-char glyph-shadow" style="font-size: 180px;">{{ day_master }}</text>
    <text x="150" y="240" class="glyph stem-char el-{{ dm_element_class }}" style="font-size: 180px;">{{ day_master }}</text>
    <text x="150" y="325" class="ru-text dm-name-big" text-anchor="middle">{{ day_master_ru }}</text>
    <line x1="40" y1="370" x2="260" y2="370" class="border"/>
    <text x="150" y="408" class="ru-text ru-sub" text-anchor="middle">{{ chart_kind }}</text>
  </g>

  <!-- Wuxing wheel: wide card on the right -->
  <g transform="translate(360, 700)">
    <rect class="card" x="0" y="0" width="800" height="440" rx="6"/>
    <text x="32" y="32" class="ru-text ru-sub">ЦИКЛ У-СИН</text>

    <!-- Legend (absolute coords inside the wuxing card — no nested
         transform, since CairoSVG sometimes drops them on polygons). -->
    <g transform="translate(530, 32)">
      <line x1="0" y1="0" x2="24" y2="0" class="legend-line"/>
      <!-- Same calligraphic silhouette as the wheel arrows (length=22,
           half_w=7 for gen, length=18, half_w=5.5 for ctrl), drawn flat
           horizontally (tangent (1,0), perpendicular (0,1)). -->
      <path d="M 30,0 Q 19.8,-4.6 8,-7 L 8,7 Q 19.8,4.6 30,0 Z" class="arrow-tip-gen"/>
      <text x="42" y="4" class="ru-text ru-sub">порождение</text>
      <line x1="140" y1="0" x2="166" y2="0" class="legend-ctrl"/>
      <path d="M 170,0 Q 161.6,-3.6 152,-5.5 L 152,5.5 Q 161.6,3.6 170,0 Z" class="arrow-tip-ctrl"/>
      <text x="180" y="4" class="ru-text ru-sub">контроль</text>
    </g>

    <!-- Pentagon centred (card width 800, centre x=400; vertical centre y=255
         leaves ≥40px above for the top role label and ≥40px below for the two
         bottom labels — both relative to the 440-tall card). -->
    <g transform="translate(400, 255)">
      <!-- Each arrow paints with its own start→end colour gradient — the
           energy reads as flowing INTO the destination element instead of
           anonymous gold or grey computer lines. Inline gradient because
           positions are unique per arrow. -->
      <defs>
        {% for ar in wuxing.arrows_ctrl %}
        <linearGradient id="ctrl-grad-{{ loop.index }}" gradientUnits="userSpaceOnUse"
                        x1="{{ ar.x1 }}" y1="{{ ar.y1 }}" x2="{{ ar.x2 }}" y2="{{ ar.y2 }}">
          <stop offset="0%" stop-color="{{ ar.src_color }}" stop-opacity="0.65"/>
          <stop offset="100%" stop-color="{{ ar.dst_color }}" stop-opacity="0.85"/>
        </linearGradient>
        {% endfor %}
        {% for ar in wuxing.arrows_gen %}
        <linearGradient id="gen-grad-{{ loop.index }}" gradientUnits="userSpaceOnUse"
                        x1="{{ ar.x1 }}" y1="{{ ar.y1 }}" x2="{{ ar.x2 }}" y2="{{ ar.y2 }}">
          <stop offset="0%" stop-color="{{ ar.src_color }}"/>
          <stop offset="100%" stop-color="{{ ar.dst_color }}"/>
        </linearGradient>
        {% endfor %}
      </defs>
      {% for ar in wuxing.arrows_ctrl %}
      <path d="{{ ar.d }}" class="arrow-ctrl"
            stroke="url(#ctrl-grad-{{ loop.index }})"/>
      <path d="{{ ar.tip_ctrl_d }}" class="arrow-tip-ctrl" filter="url(#tip-shadow)"/>
      {% endfor %}
      {% for ar in wuxing.arrows_gen %}
      <path d="{{ ar.d }}" class="arrow-line"
            stroke="url(#gen-grad-{{ loop.index }})"/>
      <path d="{{ ar.tip_gen_d }}" class="arrow-tip-gen" filter="url(#tip-shadow)"/>
      {% endfor %}
      {% for el in wuxing.elements %}
      {% set ic_r = 36 if el.is_dm else 32 %}
      {% if el.is_dm %}
      <circle cx="{{ el.cx }}" cy="{{ el.cy }}" r="54" fill="none" stroke="#c69853" stroke-width="2.5" stroke-dasharray="5 4"/>
      {% endif %}
      <!-- Coloured element disc as a clean background. The white SVG glyph
           fallback was removed after OpenMoji Color landed (L-1, 2026-05-16):
           with a working emoji font the fallback icons leak through OpenMoji's
           translucent edges and the wheel reads as a double-stamp. If the
           runtime ever loses its emoji font again, the prod symptom will be
           a blank coloured disc rather than tofu — easier to diagnose than
           the old overlapping look. -->
      <circle cx="{{ el.cx }}" cy="{{ el.cy }}" r="{{ ic_r }}" class="el-bg-{{ el.el }}"/>
      <text x="{{ el.cx }}" y="{{ el.cy + (26 if el.is_dm else 20) }}"
            class="wuxing-emoji{% if el.is_dm %} wuxing-emoji-dm{% endif %}">{{ el.emoji }}</text>
      <text x="{{ el.label_cx }}" y="{{ el.label_cy }}"
            class="ru-text role-label{% if el.is_dm %} role-label-dm{% endif %}"
            text-anchor="{{ el.label_anchor }}">{{ el.role }}</text>
      {% endfor %}
    </g>
  </g>

  <!-- Balance bars: wider strip, more breathing room -->
  <g transform="translate(40, 1160)">
    <rect class="card" x="0" y="0" width="1120" height="220" rx="6"/>
    <text x="24" y="32" class="ru-text ru-sub" style="letter-spacing: 1.2px;">БАЛАНС ЭЛЕМЕНТОВ</text>
    {% for row in balance %}
    {% set y = 58 + loop.index0 * 30 %}
    <text x="24" y="{{ y + 10 }}" class="balance-glyph el-{{ row.el_class }}">{{ row.glyph }}</text>
    <text x="60" y="{{ y + 10 }}" class="balance-label">{{ row.name_ru }}</text>
    <rect x="200" y="{{ y - 2 }}" width="830" height="16" fill="#eee5cd" rx="3"/>
    <rect x="200" y="{{ y - 2 }}" width="{{ 8.3 * row.pct_int }}" height="16" class="el-bg-{{ row.el_class }}" rx="3"/>
    <text x="1095" y="{{ y + 10 }}" class="balance-pct" text-anchor="end">{{ row.pct_int }}%</text>
    {% endfor %}
  </g>

  <!-- Footer -->
  <text x="600" y="1395" class="ru-text footer">БАЦЗЫ КАРТА · АНАСТАСИЯ · @EdoHa_Badzi_bot</text>
</svg>
