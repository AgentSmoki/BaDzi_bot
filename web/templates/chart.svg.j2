<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 1100" width="1200" height="1100">
  <defs>
    <style type="text/css"><![CDATA[
      .bg          { fill: #faf6ec; }
      .card        { fill: #ffffff; stroke: #d4cdb6; stroke-width: 1.5; }
      .card-head   { fill: #6e5832; }
      .border      { stroke: #cbc0a3; stroke-width: 1; fill: none; }
      .ru-text     { font-family: "Inter", "Helvetica Neue", "Helvetica", Arial, "PingFang SC", "Noto Sans SC", sans-serif; fill: #3d2f18; }
      .label-sm    { font-size: 14px; fill: #ffffff; font-weight: 600; letter-spacing: 1px; }
      .ru-meta     { font-size: 14px; fill: #6e5832; }
      .ru-sub      { font-size: 13px; fill: #8a7250; }
      .title       { font-family: "Inter", "Helvetica Neue", "PingFang SC", "Noto Sans SC", "Hiragino Sans GB", sans-serif; font-size: 28px; font-weight: 700; fill: #2d1f10; }
      .subtitle    { font-size: 16px; fill: #6e5832; }
      .glyph       { font-family: "PingFang SC", "Hiragino Sans GB", "Noto Sans SC", "Noto Serif SC", "Songti SC", serif; font-weight: 700; text-anchor: middle; }
      .stem-char   { font-size: 110px; }
      .branch-char { font-size: 100px; }
      .hidden-char { font-size: 30px; fill: #8a7250; }
      .ten-god     { font-size: 22px; fill: #4a3a20; }
      .footer      { font-size: 13px; fill: #8a7250; text-anchor: middle; letter-spacing: 1.5px; }
      .balance-label  { font-family: "Inter", sans-serif; font-size: 16px; fill: #3d2f18; }
      .balance-glyph  { font-family: "PingFang SC", "Noto Sans SC", serif; font-size: 22px; font-weight: 700; }
      .balance-pct    { font-family: "Inter", sans-serif; font-size: 14px; fill: #6e5832; }
      .el-wood    { fill: #5fa86a; }
      .el-fire    { fill: #d04a3a; }
      .el-earth   { fill: #a06030; }
      .el-metal   { fill: #7a8190; }
      .el-water   { fill: #3a78c4; }
      .el-bg-wood   { fill: #5fa86a; }
      .el-bg-fire   { fill: #d04a3a; }
      .el-bg-earth  { fill: #a06030; }
      .el-bg-metal  { fill: #7a8190; }
      .el-bg-water  { fill: #3a78c4; }
      .dm-glow {
        stroke: #c69853;
        stroke-width: 3;
        fill: none;
      }
    ]]></style>
  </defs>

  <!-- Background -->
  <rect class="bg" width="1200" height="1100"/>

  <!-- Header -->
  <text x="40" y="55" class="ru-text title">{{ title }}</text>
  <text x="1160" y="55" class="ru-text subtitle" text-anchor="end">{{ subtitle }}</text>
  <line x1="40" y1="75" x2="1160" y2="75" class="border"/>

  <!-- Pillars row -->
  {% for p in pillars %}
  {% set x0 = 40 + loop.index0 * 282 %}
  <g transform="translate({{ x0 }}, 100)">
    <!-- Card -->
    <rect class="card" x="0" y="0" width="270" height="580" rx="6"/>
    <!-- Top label bar -->
    <rect class="card-head" x="0" y="0" width="270" height="36" rx="6"/>
    <rect class="card-head" x="0" y="20" width="270" height="16"/>
    <text x="135" y="24" class="label-sm" text-anchor="middle">{{ p.label }}</text>
    <!-- Stem yin/yang label -->
    <text x="135" y="62" class="ru-text ru-meta" text-anchor="middle">{{ p.stem_yin_yang }}</text>
    <!-- Stem char (big) -->
    <text x="135" y="200" class="glyph stem-char el-{{ p.stem_el }}">{{ p.stem }}</text>
    {% if p.is_day %}
    <circle cx="135" cy="170" r="68" class="dm-glow"/>
    {% endif %}
    <!-- Branch yin/yang label -->
    <text x="135" y="248" class="ru-text ru-meta" text-anchor="middle">{{ p.branch_yin_yang }}</text>
    <!-- Branch char (big) -->
    <text x="135" y="380" class="glyph branch-char el-{{ p.branch_el }}">{{ p.branch }}</text>
    <!-- Animal -->
    <text x="135" y="420" class="ru-text ru-meta" text-anchor="middle">{{ p.branch_animal }}</text>
    <!-- Divider -->
    <line x1="20" y1="445" x2="250" y2="445" class="border"/>
    <!-- Hidden stems -->
    <text x="135" y="478" class="ru-text ru-sub" text-anchor="middle">скрытые</text>
    <text x="135" y="510" class="glyph hidden-char">{{ p.hidden_str }}</text>
    <!-- Ten god (stem) -->
    <line x1="20" y1="525" x2="250" y2="525" class="border"/>
    <text x="135" y="555" class="glyph ten-god">{{ p.ten_god_stem }}</text>
  </g>
  {% endfor %}

  <!-- Day master strip -->
  <g transform="translate(40, 700)">
    <rect class="card" x="0" y="0" width="1120" height="60" rx="6"/>
    <text x="20" y="38" class="ru-text ru-meta">ДНЕВНОЙ МАСТЕР</text>
    <text x="195" y="42" class="glyph el-{{ dm_element_class }}" style="font-size: 36px; text-anchor: start;">{{ day_master }}</text>
    <text x="245" y="38" class="ru-text title" style="font-size: 22px;">{{ day_master_ru }}</text>
    <text x="1100" y="38" class="ru-text ru-sub" text-anchor="end">{{ chart_kind }}</text>
  </g>

  <!-- U-Xing wheel + balance grid -->
  <g transform="translate(40, 790)">
    <rect class="card" x="0" y="0" width="1120" height="240" rx="6"/>

    <!-- U-Xing wheel (left half) — pentagon arrangement, day master ringed in gold -->
    <g transform="translate(170, 125)">
      {% for el in wuxing %}
      <circle cx="{{ el.cx }}" cy="{{ el.cy }}" r="38" class="el-bg-{{ el.cls }}" opacity="{{ '1.0' if el.is_dm else '0.6' }}"/>
      <text x="{{ el.cx }}" y="{{ el.cy + 10 }}" class="glyph" style="font-size: 28px; fill: #ffffff;">{{ el.glyph }}</text>
      {% if el.is_dm %}
      <circle cx="{{ el.cx }}" cy="{{ el.cy }}" r="46" class="dm-glow"/>
      {% endif %}
      {% endfor %}
    </g>

    <!-- Balance bars (right half) -->
    <g transform="translate(380, 30)">
      <text x="0" y="0" class="ru-text ru-sub">БАЛАНС ЭЛЕМЕНТОВ</text>
      {% for row in balance %}
      {% set y = 22 + loop.index0 * 38 %}
      <text x="0" y="{{ y + 16 }}" class="balance-glyph el-{{ row.el_class }}">{{ row.glyph }}</text>
      <text x="36" y="{{ y + 16 }}" class="balance-label">{{ row.name_ru }}</text>
      <rect x="160" y="{{ y + 4 }}" width="500" height="14" fill="#eee5cd" rx="3"/>
      <rect x="160" y="{{ y + 4 }}" width="{{ 5.0 * row.pct_int }}" height="14" class="el-bg-{{ row.el_class }}" rx="3"/>
      <text x="700" y="{{ y + 16 }}" class="balance-pct">{{ row.pct_int }}%</text>
      {% endfor %}
    </g>
  </g>

  <!-- Footer -->
  <text x="600" y="1075" class="ru-text footer">БАЦЗЫ КАРТА · АНАСТАСИЯ · @EdoHa_Badzi_bot</text>
</svg>
