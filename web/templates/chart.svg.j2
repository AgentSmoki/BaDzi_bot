<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 1380" width="1200" height="1380">
  <defs>
    <style type="text/css"><![CDATA[
      .bg          { fill: #faf6ec; }
      .card        { fill: #ffffff; stroke: #d4cdb6; stroke-width: 1.5; }
      .card-empty  { fill: #f5f1e3; stroke: #d4cdb6; stroke-width: 1.5; stroke-dasharray: 4 4; }
      .card-head   { fill: #6e5832; }
      .card-head-empty { fill: #c5beaa; }
      .border      { stroke: #cbc0a3; stroke-width: 1; fill: none; }
      .ru-text     { font-family: "Inter", "Helvetica Neue", "Helvetica", Arial, "PingFang SC", "Noto Sans SC", sans-serif; fill: #3d2f18; }
      .label-sm    { font-size: 14px; fill: #ffffff; font-weight: 600; letter-spacing: 1px; }
      .ru-meta     { font-size: 14px; fill: #6e5832; }
      .ru-sub      { font-size: 13px; fill: #8a7250; }
      .ru-mute     { font-size: 14px; fill: #a99c81; }
      .title       { font-family: "Inter", "Helvetica Neue", sans-serif; font-size: 28px; font-weight: 700; fill: #2d1f10; }
      .subtitle    { font-size: 16px; fill: #6e5832; }
      .glyph       { font-family: "PingFang SC", "Hiragino Sans GB", "Noto Sans SC", "Noto Serif SC", "Songti SC", serif; font-weight: 700; text-anchor: middle; }
      .stem-char   { font-size: 110px; }
      .branch-char { font-size: 100px; }
      .hidden-char { font-size: 30px; fill: #8a7250; }
      .hidden-stem { font-weight: 700; }
      .hidden-yy   { font-size: 11px; fill: #8a7250; }
      .ten-god     { font-size: 22px; fill: #4a3a20; }
      .placeholder { font-size: 90px; fill: #c5beb0; text-anchor: middle; }
      .footer      { font-size: 13px; fill: #8a7250; text-anchor: middle; letter-spacing: 1.5px; }
      .balance-label  { font-family: "Inter", sans-serif; font-size: 16px; fill: #3d2f18; }
      .balance-glyph  { font-family: "PingFang SC", "Noto Sans SC", serif; font-size: 22px; font-weight: 700; }
      .balance-pct    { font-family: "Inter", sans-serif; font-size: 14px; fill: #6e5832; }
      .role-label  { font-family: "Inter", sans-serif; font-size: 14px; font-weight: 600; fill: #3d2f18; }
      .role-label-dm { fill: #6e5832; font-size: 15px; }
      .arrow-line  { stroke: #b0a587; stroke-width: 2.5; fill: none; }
      .arrow-ctrl  { stroke: #c46c4a; stroke-width: 1.6; fill: none; stroke-dasharray: 5 4; opacity: 0.85; }
      .el-wood    { fill: #5fa86a; }
      .el-fire    { fill: #d04a3a; }
      .el-earth   { fill: #a06030; }
      .el-metal   { fill: #7a8190; }
      .el-water   { fill: #3a78c4; }
      .el-bg-wood   { fill: #5fa86a; }
      .el-bg-fire   { fill: #d04a3a; }
      .el-bg-earth  { fill: #a06030; }
      .el-bg-metal  { fill: #7a8190; }
      .el-bg-water  { fill: #3a78c4; }
    ]]></style>

    <!-- Arrowhead for generation cycle (filled muted gold) -->
    <marker id="gen-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="9" markerHeight="9" orient="auto-start-reverse">
      <path d="M 0 0 L 10 5 L 0 10 z" fill="#b0a587"/>
    </marker>
    <!-- Arrowhead for control cycle (smaller, terracotta) -->
    <marker id="ctrl-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
      <path d="M 0 0 L 10 5 L 0 10 z" fill="#c46c4a"/>
    </marker>

    <!-- Element icons as reusable symbols (no Chinese glyphs) -->
    <symbol id="ic-wood" viewBox="-30 -30 60 60">
      <rect x="-4" y="-2" width="8" height="22" fill="#3a5b1f"/>
      <circle cx="0" cy="-8" r="20" fill="#ffffff" opacity="0.92"/>
      <circle cx="-7" cy="-12" r="9" fill="#ffffff" opacity="0.92"/>
      <circle cx="9" cy="-10" r="8" fill="#ffffff" opacity="0.92"/>
      <circle cx="0" cy="-3" r="9" fill="#ffffff" opacity="0.92"/>
    </symbol>
    <symbol id="ic-fire" viewBox="-30 -30 60 60">
      <path d="M 0,-22 C -10,-10 -16,0 -14,8 C -12,18 -4,22 0,22 C 6,22 14,18 14,6 C 14,-2 8,-12 0,-22 Z M -3,4 C -2,-2 1,-6 4,-10 C 6,-2 8,4 6,10 C 4,16 -2,17 -4,12 C -6,8 -5,6 -3,4 Z" fill="#ffffff" opacity="0.95"/>
    </symbol>
    <symbol id="ic-earth" viewBox="-30 -30 60 60">
      <path d="M -22,16 L -8,-4 L -2,8 L 6,-12 L 22,16 Z" fill="#ffffff" opacity="0.95"/>
      <circle cx="-12" cy="-12" r="3" fill="#ffffff"/>
    </symbol>
    <symbol id="ic-metal" viewBox="-30 -30 60 60">
      <circle cx="0" cy="0" r="20" fill="none" stroke="#ffffff" stroke-width="3.5"/>
      <circle cx="0" cy="0" r="6" fill="#ffffff"/>
      <line x1="-26" y1="0" x2="-22" y2="0" stroke="#ffffff" stroke-width="3.5"/>
      <line x1="22" y1="0" x2="26" y2="0" stroke="#ffffff" stroke-width="3.5"/>
      <line x1="0" y1="-26" x2="0" y2="-22" stroke="#ffffff" stroke-width="3.5"/>
      <line x1="0" y1="22" x2="0" y2="26" stroke="#ffffff" stroke-width="3.5"/>
    </symbol>
    <symbol id="ic-water" viewBox="-30 -30 60 60">
      <path d="M 0,-22 C -12,-6 -16,4 -16,10 C -16,18 -8,24 0,24 C 8,24 16,18 16,10 C 16,4 12,-6 0,-22 Z" fill="#ffffff" opacity="0.95"/>
      <ellipse cx="-5" cy="6" rx="3" ry="6" fill="#ffffff" opacity="0.5"/>
    </symbol>
  </defs>

  <!-- Background -->
  <rect class="bg" width="1200" height="1380"/>

  <!-- Header -->
  <text x="40" y="55" class="ru-text title">{{ title }}</text>
  <text x="1160" y="55" class="ru-text subtitle" text-anchor="end">{{ subtitle }}</text>
  <line x1="40" y1="75" x2="1160" y2="75" class="border"/>

  <!-- Pillars row (always 4 columns, hour can be empty placeholder) -->
  {% for p in pillars %}
  {% set x0 = 40 + loop.index0 * 282 %}
  <g transform="translate({{ x0 }}, 100)">
    {% if p.empty %}
    <rect class="card-empty" x="0" y="0" width="270" height="580" rx="6"/>
    <rect class="card-head-empty" x="0" y="0" width="270" height="36" rx="6"/>
    <rect class="card-head-empty" x="0" y="20" width="270" height="16"/>
    <text x="135" y="24" class="label-sm" text-anchor="middle">{{ p.label }}</text>
    <text x="135" y="220" class="placeholder">—</text>
    <text x="135" y="400" class="placeholder">—</text>
    <text x="135" y="480" class="ru-text ru-mute" text-anchor="middle">время не указано</text>
    <text x="135" y="510" class="ru-text ru-sub" text-anchor="middle">столп часа не построен</text>
    {% else %}
    <rect class="card" x="0" y="0" width="270" height="580" rx="6"/>
    <rect class="card-head" x="0" y="0" width="270" height="36" rx="6"/>
    <rect class="card-head" x="0" y="20" width="270" height="16"/>
    <text x="135" y="24" class="label-sm" text-anchor="middle">{{ p.label }}</text>
    <text x="135" y="62" class="ru-text ru-meta" text-anchor="middle">{{ p.stem_yin_yang }}</text>
    <text x="135" y="200" class="glyph stem-char el-{{ p.stem_el }}">{{ p.stem }}</text>
    <text x="135" y="248" class="ru-text ru-meta" text-anchor="middle">{{ p.branch_yin_yang }}</text>
    <text x="135" y="380" class="glyph branch-char el-{{ p.branch_el }}">{{ p.branch }}</text>
    <text x="135" y="420" class="ru-text ru-meta" text-anchor="middle">{{ p.branch_animal }}</text>
    <line x1="20" y1="445" x2="250" y2="445" class="border"/>
    <text x="135" y="465" class="ru-text ru-sub" text-anchor="middle">скрытые</text>
    {% if p.hidden_list %}
      {% for hs in p.hidden_list %}
      <text x="{{ hs.x }}" y="500" class="glyph hidden-stem el-{{ hs.el }}" style="font-size: 32px;">{{ hs.char }}</text>
      <text x="{{ hs.x }}" y="520" class="ru-text hidden-yy" text-anchor="middle">{{ hs.yin_yang }}</text>
      {% endfor %}
    {% else %}
      <text x="135" y="500" class="glyph hidden-char">—</text>
    {% endif %}
    <line x1="20" y1="535" x2="250" y2="535" class="border"/>
    <text x="135" y="563" class="glyph ten-god">{{ p.ten_god_stem }}</text>
    {% endif %}
  </g>
  {% endfor %}

  <!-- Господин дня strip -->
  <g transform="translate(40, 700)">
    <rect class="card" x="0" y="0" width="1120" height="60" rx="6"/>
    <text x="20" y="38" class="ru-text ru-meta">ГОСПОДИН ДНЯ</text>
    <text x="195" y="42" class="glyph el-{{ dm_element_class }}" style="font-size: 36px; text-anchor: start;">{{ day_master }}</text>
    <text x="245" y="38" class="ru-text title" style="font-size: 22px;">{{ day_master_ru }}</text>
    <text x="1100" y="38" class="ru-text ru-sub" text-anchor="end">{{ chart_kind }}</text>
  </g>

  <!-- Wuxing wheel: pentagon, day master on top, generation arrows, role labels -->
  <g transform="translate(40, 790)">
    <rect class="card" x="0" y="0" width="1120" height="380" rx="6"/>
    <text x="40" y="36" class="ru-text ru-sub">ЦИКЛ У-СИН</text>

    <!-- Legend: solid arrow = generation, dashed = control -->
    <g transform="translate(820, 32)">
      <line x1="0" y1="0" x2="30" y2="0" class="arrow-line" marker-end="url(#gen-arrow)"/>
      <text x="38" y="4" class="ru-text ru-sub">порождение</text>
      <line x1="160" y1="0" x2="190" y2="0" class="arrow-ctrl" marker-end="url(#ctrl-arrow)"/>
      <text x="200" y="4" class="ru-text ru-sub">контроль</text>
    </g>

    <g transform="translate(280, 220)">
      <!-- Control arrows first so they sit visually behind the generation cycle -->
      {% for ar in wuxing.arrows_ctrl %}
      <line x1="{{ ar.x1 }}" y1="{{ ar.y1 }}" x2="{{ ar.x2 }}" y2="{{ ar.y2 }}"
            class="arrow-ctrl" marker-end="url(#ctrl-arrow)"/>
      {% endfor %}

      <!-- Generation arrows (clockwise pentagon perimeter) -->
      {% for ar in wuxing.arrows_gen %}
      <line x1="{{ ar.x1 }}" y1="{{ ar.y1 }}" x2="{{ ar.x2 }}" y2="{{ ar.y2 }}"
            class="arrow-line" marker-end="url(#gen-arrow)"/>
      {% endfor %}

      <!-- Element circles + icons + role labels -->
      {% for el in wuxing.elements %}
      <circle cx="{{ el.cx }}" cy="{{ el.cy }}" r="{{ wuxing.icon_radius }}"
              class="el-bg-{{ el.el }}" opacity="{{ '1.0' if el.is_dm else '0.7' }}"/>
      <use href="#ic-{{ el.el }}" x="{{ el.cx - wuxing.icon_radius }}"
           y="{{ el.cy - wuxing.icon_radius }}" width="{{ wuxing.icon_radius * 2 }}"
           height="{{ wuxing.icon_radius * 2 }}"/>
      <text x="{{ el.label_cx }}" y="{{ el.label_cy }}"
            class="ru-text role-label{% if el.is_dm %} role-label-dm{% endif %}"
            text-anchor="{{ el.label_anchor }}">{{ el.role }}</text>
      {% endfor %}
    </g>
  </g>

  <!-- Balance bars -->
  <g transform="translate(40, 1190)">
    <rect class="card" x="0" y="0" width="1120" height="160" rx="6"/>
    <text x="20" y="32" class="ru-text ru-sub">БАЛАНС ЭЛЕМЕНТОВ</text>
    {% for row in balance %}
    {% set y = 50 + loop.index0 * 22 %}
    <text x="20" y="{{ y + 8 }}" class="balance-glyph el-{{ row.el_class }}">{{ row.glyph }}</text>
    <text x="56" y="{{ y + 8 }}" class="balance-label">{{ row.name_ru }}</text>
    <rect x="180" y="{{ y - 4 }}" width="850" height="14" fill="#eee5cd" rx="3"/>
    <rect x="180" y="{{ y - 4 }}" width="{{ 8.5 * row.pct_int }}" height="14" class="el-bg-{{ row.el_class }}" rx="3"/>
    <text x="1095" y="{{ y + 8 }}" class="balance-pct" text-anchor="end">{{ row.pct_int }}%</text>
    {% endfor %}
  </g>

  <!-- Footer -->
  <text x="600" y="1370" class="ru-text footer">БАЦЗЫ КАРТА · АНАСТАСИЯ · @EdoHa_Badzi_bot</text>
</svg>
