# =============================================================
# БаЦзы-Бот — переменные окружения
# Скопируй в .env и заполни значения. Никогда не коммить .env!
# =============================================================

# --- Telegram ---
BOT_TOKEN=
ADMIN_TELEGRAM_ID=

# --- Database (self-hosted контейнеры в docker-compose на Timeweb) ---
# DATABASE_URL смотрит на внутренний сервис `db`; пароль = POSTGRES_PASSWORD
# (compose подставляет его в контейнер db, значения должны совпадать).
POSTGRES_PASSWORD=
DATABASE_URL=postgresql+asyncpg://badzi:CHANGEME@db:5432/badzi
REDIS_URL=redis://redis:6379/0

# --- AI (OpenRouter — единый провайдер, ADR-012) ---
# Весь LLM-трафик идёт через OpenRouter (не только emergency). Пополнить
# баланс. Tier 1 — основной ответчик (Qwen3.7-Plus), Tier 2 — резерв на
# 429/5xx (Gemini 2.5 Pro — другая семья моделей).
OPENROUTER_API_KEY=
PRIMARY_MODEL=qwen/qwen3.7-plus
PRIMARY_CONTEXT=1000000
EMERGENCY_MODEL=google/gemini-2.5-pro
EMERGENCY_CONTEXT=1000000

# --- AI shared ---
LLM_TIMEOUT=60
MAX_OUTPUT_TOKENS_CEILING=32000

# --- Fast LLM (skill-router / smart-entry / concept-extract / day-image) ---
# Дешёвая быстрая модель для классификации и JSON-выхода (Gemini Flash).
FAST_MODEL=google/gemini-2.5-flash
# Запас под reasoning; неиспользованный бюджет не биллится.
FAST_MAX_TOKENS=4000
# Feature flag — flip to false (Redis override at runtime) to revert to
# the legacy single-prompt flow.
SKILL_ROUTER_ENABLED=true

# --- Swiss Ephemeris ---
SWISS_EPHEMERIS_PATH=/usr/share/swisseph

# --- Geocoding ---
GEOCODING_PROVIDER=nominatim
# Primary: Google Geocoding + TimeZone API. ~40k/мес free via $200 credit.
GOOGLE_GEOCODER_API_KEY=
# Fallback: Yandex Geocoder. 25k/день free tier. IANA tz computed locally
# via timezonefinder (Yandex не отдаёт IANA).
YANDEX_GEOCODER_API_KEY=

# --- KuzuDB (knowledge graph) ---
KUZU_DB_PATH=./knowledge/kuzu_db

# --- Unsplash (Wave 7 Phase E — daily forecast hero image) ---
# Register: https://unsplash.com/developers → New Application. Free tier
# 50 req/hour is plenty for the forecast scheduler. Leave blank to skip
# the hero image (forecast text still sends).
UNSPLASH_APPLICATION_ID=
UNSPLASH_ACCESS_KEY=
UNSPLASH_SECRET_KEY=

# --- Payments ---
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=
# Telegram-native payments provider token (ЮKassa) из @BotFather → Payments.
# Формат 381764678:TEST:... (тест) или :LIVE:... (прод). Пусто = оплата
# выключена (работает free-bypass). Реальная оплата включается когда задан
# токен И FORECAST_FREE_BYPASS=false.
TELEGRAM_PAYMENT_PROVIDER_TOKEN=

# --- Monitoring (Langfuse) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Web / Admin ---
WEB_BASE_URL=https://badzi-bot.your-domain.ru
ADMIN_BASIC_AUTH_USER=admin
ADMIN_BASIC_AUTH_PASSWORD=

# --- Card rendering (CairoSVG via ProcessPoolExecutor; ADR-007) ---
HIEROGLYPHS_PATH=./assets/hieroglyphs
# RENDER_POOL_SIZE=4   # optional override; default = cpu_count() // 2

# --- Feature Flags (overridden by Redis at runtime) ---
AI_ENABLED=true
PAYMENTS_ENABLED=true
CARD_RENDERING_ENABLED=true

# --- App ---
ENVIRONMENT=development
LOG_LEVEL=INFO
