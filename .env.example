# =============================================================
# БаЦзы-Бот — переменные окружения
# Скопируй в .env и заполни значения. Никогда не коммить .env!
# =============================================================

# --- Telegram ---
BOT_TOKEN=
ADMIN_TELEGRAM_ID=

# --- Database (Yandex Managed PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/badzi
REDIS_URL=redis://host:6379/0

# --- AI (Yandex AI Studio — Tier 1 primary, ADR-009) ---
# Create via: yc iam service-account create + yc resource-manager folder
# add-access-binding --role ai.languageModels.user + yc iam api-key create
YC_AI_API_KEY=
YC_AI_FOLDER_ID=
YC_PRIMARY_MODEL=qwen3.6-35b-a3b
YC_QWEN36_CONTEXT=262144

# --- AI (OpenRouter — Tier 2 emergency fallback, ADR-009) ---
# Independent cloud + provider. Triggered when YC fails. Top up with ~5 USD.
OPENROUTER_API_KEY=
OPENROUTER_EMERGENCY_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_CLAUDE_CONTEXT=200000

# --- AI shared ---
LLM_TIMEOUT=60
MAX_OUTPUT_TOKENS_CEILING=32000

# --- Skill router (Wave 6, ADR-010) ---
# Fast LLM that classifies questions into a skill (work/relationships/
# health/time/default). Defaults to the same Qwen3.6 as primary because
# Qwen3-3B isn't yet in the YC catalog (probe HTTP 400 on 2026-05-19).
# Swap to qwen3-3b once available — see task 1.17.8.
YC_FAST_MODEL=qwen3.6-35b-a3b
# 4000 chosen with safety margin — Qwen3.6 thinking burns reasoning_content
# first; live smoke 2026-05-20 hit ~1949 tokens on 2000 cap → finish_reason
# =length with empty content. JSON itself is ~150-300 tokens, so 4000 =
# ~3000 reasoning headroom + 1000 JSON. Unused budget is not billed.
YC_FAST_MAX_TOKENS=4000
# Feature flag — flip to false (Redis override at runtime) to revert to
# the legacy single-prompt flow.
SKILL_ROUTER_ENABLED=true

# --- Swiss Ephemeris ---
SWISS_EPHEMERIS_PATH=/usr/share/swisseph

# --- Geocoding ---
GEOCODING_PROVIDER=nominatim
# Primary: Google Geocoding + TimeZone API. ~40k/мес free via $200 credit.
GOOGLE_GEOCODER_API_KEY=
# Fallback: Yandex Geocoder. 25k/день free tier. IANA tz computed locally
# via timezonefinder (Yandex не отдаёт IANA).
YANDEX_GEOCODER_API_KEY=

# --- KuzuDB (knowledge graph) ---
KUZU_DB_PATH=./knowledge/kuzu_db

# --- Yandex Object Storage (S3-compatible) ---
YC_OBJECT_STORAGE_BUCKET=badzi-bot-assets
YC_ACCESS_KEY_ID=
YC_SECRET_ACCESS_KEY=
YC_ENDPOINT_URL=https://storage.yandexcloud.net

# --- Payments ---
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=

# --- Monitoring (Langfuse) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Web / Admin ---
WEB_BASE_URL=https://badzi-bot.your-domain.ru
ADMIN_BASIC_AUTH_USER=admin
ADMIN_BASIC_AUTH_PASSWORD=

# --- Card rendering (CairoSVG via ProcessPoolExecutor; ADR-007) ---
HIEROGLYPHS_PATH=./assets/hieroglyphs
# RENDER_POOL_SIZE=4   # optional override; default = cpu_count() // 2

# --- Feature Flags (overridden by Redis at runtime) ---
AI_ENABLED=true
PAYMENTS_ENABLED=true
CARD_RENDERING_ENABLED=true

# --- App ---
ENVIRONMENT=development
LOG_LEVEL=INFO
